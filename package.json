{
  "name": "wepersona",
  "version": "2.0.1",
  "description": "WePersona - 微信聊天助手，整合数字人格与AI聊天功能",
  "main": "dist-electron/main.js",
  "author": {
    "name": "WePersona Team",
    "email": "support@wepersona.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/le700/wepersona"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps && node scripts/prepare-electron-runtime.cjs",
    "rebuild": "electron-rebuild",
    "dev": "node scripts/prepare-electron-runtime.cjs && vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build && electron-builder",
    "build:frontend": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "node scripts/prepare-electron-runtime.cjs && vite --mode electron",
    "electron:build": "npm run build"
  },
  "dependencies": {
    "@vscode/sudo-prompt": "^9.3.2",
    "axios": "^1.6.0",
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "echarts-wordcloud": "^2.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "ffmpeg-static": "^5.3.0",
    "fzstd": "^0.1.1",
    "html2canvas": "^1.4.1",
    "jieba-wasm": "^2.2.0",
    "jszip": "^3.10.1",
    "koffi": "^2.9.0",
    "lucide-react": "^1.8.0",
    "openai": "^4.52.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "react-virtuoso": "^4.18.5",
    "remark": "^14.0.2",
    "remark-gfm": "^4.0.1",
    "sherpa-onnx-node": "^1.10.38",
    "silk-wasm": "^3.7.1",
    "strip-markdown": "^5.0.0",
    "wechat-emojis": "^1.0.2",
    "wechaty": "^1.20.2",
    "wechaty-puppet-wechat4u": "^1.14.14",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "sass": "^1.98.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=6.2.1",
      "minimatch": ">=3.1.2",
      "rollup": ">=4.0.0",
      "immutable": ">=4.0.0",
      "lodash": ">=4.17.21",
      "brace-expansion": ">=1.1.11",
      "picomatch": ">=2.3.1",
      "ajv": ">=8.18.0"
    }
  },
  "build": {
    "appId": "com.wepersona.app",
    "publish": {
      "provider": "github",
      "owner": "le700",
      "repo": "wepersona",
      "releaseType": "release"
    },
    "productName": "WePersona",
    "artifactName": "${productName}-${version}-Setup.${ext}",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico",
      "extraFiles": [
        {
          "from": "resources/runtime/win32/msvcp140.dll",
          "to": "."
        },
        {
          "from": "resources/runtime/win32/msvcp140_1.dll",
          "to": "."
        },
        {
          "from": "resources/runtime/win32/vcruntime140.dll",
          "to": "."
        },
        {
          "from": "resources/runtime/win32/vcruntime140_1.dll",
          "to": "."
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "differentialPackage": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "unicode": true,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052",
      "displayLanguageSelector": false,
      "include": "installer.nsh",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "perMachine": false,
      "allowElevation": true,
      "installerSidebar": null,
      "uninstallerSidebar": null
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/"
      },
      {
        "from": "public/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "public/icon.png",
        "to": "icon.png"
      },
      {
        "from": "electron/assets/wasm/",
        "to": "assets/wasm/"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "node_modules/silk-wasm/**/*",
      "node_modules/sherpa-onnx-node/**/*",
      "node_modules/sherpa-onnx-*/*",
      "node_modules/sherpa-onnx-*/**/*",
      "node_modules/ffmpeg-static/**/*",
      "resources/wedecrypt/**/*.node"
    ],
    "icon": "public/icon.ico"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "tar": "^7.5.13",
    "immutable": "^5.1.5"
  }
}
